# Database Configuration (Using SQLite for local development)
DATABASE_URL=sqlite:///./task1_db.db

# For PostgreSQL in production, uncomment and update:
# DATABASE_URL=postgresql://user:password@localhost:5432/task1_db

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Third-Party LLM/Embedding API Configuration (USF)
USE_USF_API=True
USF_API_KEY=your-usf-api-key-here
USF_BASE_URL=https://api.us.inc/usf/v1
USF_CHAT_MODEL=usf1-mini
USF_EMBED_MODEL=usf1-embed
USF_RERANK_MODEL=usf1-rerank
USF_CHAT_TIMEOUT=30
USF_EMBED_TIMEOUT=10
USF_RERANK_TIMEOUT=10

# Vector Database Configuration
VECTOR_DB_PATH=./chroma_db
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Application Configuration
DEBUG=True
LOG_LEVEL=INFO
