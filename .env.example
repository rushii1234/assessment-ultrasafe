# API Configuration
API_BASE_URL=https://api.us.inc/usf/v1
API_KEY=your_api_key_here

# Chat Completion Model
CHAT_MODEL=usf1-mini
CHAT_TEMPERATURE=0.7
CHAT_MAX_TOKENS=1000

# Embedding Model
EMBEDDING_MODEL=usf1-embed

# Reranker Model
RERANK_MODEL=usf1-rerank

# FastAPI Settings
HOST=0.0.0.0
PORT=8000
DEBUG=True

# RAG Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5
RERANK_TOP_K=3
